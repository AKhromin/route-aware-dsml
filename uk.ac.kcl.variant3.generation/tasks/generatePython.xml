<?xml version="1.0" encoding="UTF-8"?>
<project default="generatePython" name="uk.ac.kcl.variant3.generation">
    <property name="ECLIPSE_HOME" value="../../../eclipse/dsl-2025-09/Eclipse.app/Contents/Eclipse"/>
    <property name="ECLIPSE_WORKSPACE" value="../.."/>

    <!-- The classpath with only the dependencies used by the project -->
    <path id="uk.ac.kcl.variant3.generation.libraryclasspath">
        <pathelement location="${ECLIPSE_WORKSPACE}/uk.ac.kcl.variant3.generation/bin"/>
    </path>

    <path id="uk.ac.kcl.variant3.generation.classpath">
        <path refid="uk.ac.kcl.variant3.generation.libraryclasspath"/>
    </path>

    <!-- The classpath with only the jars available in the plugin folder of Eclipse -->
    <path id="uk.ac.kcl.variant3.generation.libraryclasspath.alljars">
        <pathelement location="../uk.ac.kcl.variant3.generation/bin"/>
        <fileset dir="${ECLIPSE_HOME}/plugins/" includes="*.jar"/>
    </path>

    <path id="uk.ac.kcl.variant3.generation.classpath.alljars">
        <path refid="uk.ac.kcl.variant3.generation.libraryclasspath.alljars"/>
    </path>

    <!-- The default task with the jars used by this project -->
    <target name="generatePython">
        <java classname="uk.ac.kcl.variant3.generation.main.GeneratePython" classpathref="uk.ac.kcl.variant3.generation.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>

    <!--
        In case of problem you can also try with all the jar available in your Eclipse
        Keep in mind that having two versions of the same jar can create problems
    -->
    <target name="generatePython.alljars">
        <java classname="uk.ac.kcl.variant3.generation.main.GeneratePython" classpathref="uk.ac.kcl.variant3.generation.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>
</project>
